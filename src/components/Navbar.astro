<style>
  /* =========================================================
     Mind Arc — Navbar (Unified Theme)
     ========================================================= */

  /* Full-width wrapper with surface and border */
  .nav-wrapper {
    width: 100%;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    color: var(--text);
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease;
  }

  /* Centered inner container */
  .nav-container {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: "center toggle";
    align-items: center;
    padding: 1.625rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  /* Navigation links container */
  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: center;
    background-color: transparent;
  }

  /* Navigation links */
  .nav-wrapper a,
  .nav-wrapper a:link,
  .nav-wrapper a:visited,
  .nav-wrapper a:active,
  .nav-wrapper a:focus {
    font-family: "Michroma", sans-serif;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    text-align: center;
    color: var(--text);
    border-bottom: none;
    letter-spacing: 0.2em;
    transition:
      color 0.25s ease,
      opacity 0.2s ease;
  }

  /* Hover / accent state */
  .nav-wrapper a:hover {
    color: var(--accent-hover);
  }

  /* Hamburger menu (mobile) */
  .hamburger {
    display: none;
    grid-area: toggle;
    justify-self: end;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    color: var(--text);
  }

  .hamburger span {
    width: 25px;
    height: 3px;
    background-color: currentColor;
    border-radius: 3px;
    transition: background-color 0.25s ease;
  }

  /* Hide the checkbox (menu toggle) */
  .menu-toggle {
    display: none;
  }

  /* ===============================
     Mobile Styles
     =============================== */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
      flex-direction: column;
      align-items: center;
      background-color: var(--surface);
      padding: 1rem 0;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 99;
      width: 100%;
      border-top: 1px solid var(--border);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
    }

    .menu-toggle:checked ~ .nav-links {
      display: flex;
    }

    .nav-links a {
      width: 100%;
      padding: 0.75rem 1.5rem;
      border-bottom: 1px solid
        color-mix(in oklab, var(--border) 70%, transparent);
      text-align: center;
    }

    .hamburger {
      display: flex;
    }

    .nav-container {
      grid-template-columns: 1fr auto;
      padding: 10px 5px;
    }
  }
</style>

<nav class="nav-wrapper">
  <div class="nav-container">
    <input type="checkbox" id="menu-toggle" class="menu-toggle" />
    <label for="menu-toggle" class="hamburger" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <div class="nav-links">
      <a href="/about">ABOUT</a>
      <a href="/news">NEWS</a>
      <a href="/games">GAMES</a>
      <a href="/support">SUPPORT</a>
    </div>
  </div>
</nav>
