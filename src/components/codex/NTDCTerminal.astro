---
import "../../styles/codex.css";
import TerminalFooter from "./TerminalFooter.astro";

const { subtitle = "Phoenix Vector Archive", status = "Archive Node Online" } =
  Astro.props;
---

<section class="ntdc-frame">
  <header class="ntdc-nav-zone">
    <nav class="codex-nav" aria-label="Codex navigation">
      <button class="codex-nav__button" type="button" onclick="history.back()">
        Back
      </button>

      <a class="codex-nav__button" href="/phoenixvector/codex/">Codex Home</a>
      <a class="codex-nav__button" href="/phoenixvector/">Phoenix Vector</a>
      <a class="codex-nav__button" href="/">Mind Arc</a>
    </nav>
  </header>

  <div class="ntdc-display">
    <slot />
  </div>
</section>

<style>
  .ntdc-frame {
    width: min(100% - 1rem, 1120px);
    height: 100vh;
    margin: 0.75rem auto 2rem;
    padding: 1rem;
    overflow: hidden;
  }

  .ntdc-nav-zone {
    margin-bottom: 1rem;
  }

  .codex-nav {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.45rem;
  }

  .codex-nav__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    min-height: 2.6rem;
    padding: 0.75rem 0.9rem;

    border: 1px solid rgba(0, 0, 0, 0.55);
    border-radius: 0.45rem;

    background: linear-gradient(
      180deg,
      rgba(18, 18, 18, 0.92),
      rgba(4, 4, 4, 0.96)
    );

    color: var(--ntdc-hardware-yellow-bright);
    font-family: "Phoenix", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    text-decoration: none;
    text-shadow: 0 0 8px rgba(246, 180, 0, 0.4);

    cursor: pointer;
  }

  .codex-nav__button:hover,
  .codex-nav__button:focus-visible {
    color: #fff3bf;
    filter: brightness(1.08);
  }

  .ntdc-display {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .ntdc-terminal {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ntdc-terminal__header {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 0.85rem;
    padding: 0.35rem 0 0.75rem;
  }

  .ntdc-terminal__title {
    margin: 0;
    font-family: "Phoenix", sans-serif;
    font-size: clamp(1.7rem, 13vw, 3.25rem);
    line-height: 0.92;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ntdc-terminal__status {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: "Orbitron", sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--codex-muted);
  }

  .ntdc-terminal__status-dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--codex-operational);
    box-shadow: 0 0 12px var(--codex-operational);
  }

  .ntdc-terminal__screen {
    position: relative;
    z-index: 1;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    padding-right: 0.35rem;
  }

  .ntdc-terminal__screen > * {
    position: relative;
    z-index: 1;
  }

  .ntdc-terminal__footer {
    position: relative;
    z-index: 1;
    padding-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-family: "Orbitron", sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--codex-dim);
  }

  @media (min-width: 386px) {
    .codex-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 640px) {
    .ntdc-frame {
      width: min(100% - 3rem, 1120px);
      padding: 1.25rem;
      margin-block: 1.5rem 2.5rem;
    }

    .codex-nav {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 900px) {
    .ntdc-frame {
      width: min(100% - 8rem, 1120px);
      padding: 1.5rem;
      margin-block: 2.5rem 3rem;
    }
  }

  @media (min-width: 1200px) {
    .ntdc-frame {
      width: min(100% - 12rem, 1120px);
    }
  }
</style>
