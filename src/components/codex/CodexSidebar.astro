---
interface NavItem {
  title: string;
  href: string;
  status?: string;
}

interface Props {
  items?: NavItem[];
  currentPath?: string;
}

const { items = [], currentPath = "/phoenixvector/codex/" } = Astro.props;

const normalizePath = (path: string) => {
  if (!path) return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const normalizedCurrentPath = normalizePath(currentPath);
---

<aside class="codex-sidebar" aria-label="Codex navigation">
  <div class="codex-sidebar__inner">
    <div class="codex-sidebar__head">
      <p class="codex-sidebar__eyebrow">Records</p>
    </div>

    <div class="codex-sidebar__group">
      <ul class="codex-sidebar__nav">
{
  items.map((section) => {
    const isActive =
      normalizePath(section.href) === normalizedCurrentPath;

    const isDisabled = section.status === "Queued";

    return (
      <li>
        {isDisabled ? (
          <div
            class:list={[
              "codex-sidebar__link",
              "is-disabled",
              isActive && "is-active",
            ]}
          >
            <span class="codex-sidebar__link-top">
              <span class="codex-sidebar__link-title">
                {section.title}
              </span>

              {section.status && (
                <span class="codex-sidebar__link-status">
                  {section.status}
                </span>
              )}
            </span>
          </div>
        ) : (
          <a
            href={section.href}
            class:list={[
              "codex-sidebar__link",
              isActive && "is-active",
            ]}
            aria-current={isActive ? "page" : undefined}
          >
            <span class="codex-sidebar__link-top">
              <span class="codex-sidebar__link-title">
                {section.title}
              </span>

              {section.status && (
                <span class="codex-sidebar__link-status">
                  {section.status}
                </span>
              )}
            </span>
          </a>
        )}
      </li>
    );
  })
}
      </ul>
    </div>
  </div>
</aside>

<style>
  .codex-sidebar {
    position: sticky;
    top: 118px;
    align-self: start;
  }

  .codex-sidebar__inner {
    border: 1px solid rgba(103, 232, 253, 0.18);
    border-radius: 28px;
    background: linear-gradient(
      180deg,
      rgba(9, 16, 22, 0.96) 0%,
      rgba(7, 12, 18, 0.92) 100%
    );
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
    overflow: hidden;
  }

  .codex-sidebar__head {
    padding: 1.35rem 1.2rem 1rem;
    border-bottom: 1px solid rgba(103, 232, 253, 0.14);
    background: linear-gradient(
      180deg,
      rgba(103, 232, 253, 0.08) 0%,
      transparent 100%
    );
  }

  .codex-sidebar a {
    text-decoration: none;
  }

  .codex-sidebar__eyebrow {
    margin: 0;
    color: #67e8fd;
    font-family:
      "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    line-height: 1;
  }

  .codex-sidebar__group {
    padding: 1rem;
  }

  .codex-sidebar__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }

  .codex-sidebar__link {
    display: grid;
    gap: 0.32rem;
    padding: 0.9rem 0.95rem;
    border: 1px solid transparent;
    border-radius: 14px;
    background: transparent;
    color: inherit;
    transition:
      border-color 0.25s ease,
      background-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .codex-sidebar__link:hover,
  .codex-sidebar__link:focus-visible {
    border-color: rgba(103, 232, 253, 0.34);
    background: rgba(103, 232, 253, 0.06);
    transform: translateX(4px);
    box-shadow: 0 0 0 1px rgba(103, 232, 253, 0.05) inset;
    outline: none;
  }

  .codex-sidebar__link.is-active {
    border-color: rgba(103, 232, 253, 0.34);
    background:
      linear-gradient(
        90deg,
        rgba(103, 232, 253, 0.18) 0%,
        rgba(103, 232, 253, 0.04) 85%
      ),
      rgba(103, 232, 253, 0.06);
    box-shadow:
      inset 3px 0 0 #67e8fd,
      0 0 0 1px rgba(103, 232, 253, 0.05);
  }

  .codex-sidebar__link-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .codex-sidebar__link-title {
    color: #e6f6fb;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1.3;
  }

  .codex-sidebar__link-status {
    color: rgba(230, 246, 251, 0.62);
    font-family:
      "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .codex-sidebar__link.is-disabled {
  opacity: 0.35;
  cursor: not-allowed;
  pointer-events: none;
}

  @media (max-width: 920px) {
    .codex-sidebar {
      display: none;
    }
  }
</style>