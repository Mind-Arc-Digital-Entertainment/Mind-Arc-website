---
const year = new Date().getFullYear();
---

<style>
  .footer {
    width: 100%;
    margin-top: auto;
    padding: 1rem 0.75rem calc(1rem + env(safe-area-inset-bottom));
    background: color-mix(in oklab, var(--surface) 85%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--text);
    text-align: center;
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: 0.5rem;
  }

  .build-note strong {
    color: var(--accent);
  }

  .footer-subtext {
    font-size: 0.75rem;
    color: color-mix(in oklab, var(--text) 70%, transparent);
    margin-top: 0.5rem;
  }

  .footer::before {
    content: "";
    display: block;
    width: 100%;
    height: 1px;
    background: color-mix(in oklab, var(--border) 60%, transparent);
    margin-bottom: 0.75rem;
  }

  .footer-nav {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid color-mix(in oklab, var(--border) 70%, transparent);
  }

  .social-links {
    margin-top: 0.9rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .social-links a:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  .social-links img {
    width: 22px;
    height: 22px;

    /* convert black icons to cyan */
    filter: brightness(0) saturate(100%) invert(82%) sepia(19%) saturate(1170%)
      hue-rotate(154deg) brightness(98%) contrast(101%);

    opacity: 0.85;
    transition:
      transform 0.25s ease,
      filter 0.25s ease,
      opacity 0.25s ease;
  }

  .link-grid {
    list-style: none;
    margin: 0;
    padding: 0;

    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.75rem 1rem;
    font-size: 0.85rem;
  }

  .link-grid li {
    display: contents;
  }

  .link-grid a {
    color: color-mix(in oklab, var(--text) 85%, transparent);
    text-decoration: none;
    padding: 0.5rem 0.5rem;
    line-height: 1.2;
    transition: color 0.25s ease;
  }

  .link-grid a:hover {
    color: var(--accent);
  }

  .footer-contact {
    margin-top: 0.75rem;
    font-size: 0.8rem;
    color: color-mix(in oklab, var(--text) 75%, transparent);
  }

  .footer-contact a {
    color: var(--accent);
    text-decoration: none;
    margin-left: 0.25rem;
    transition: color 0.25s ease;
  }

  .footer-contact a:hover {
    color: color-mix(in oklab, var(--accent) 80%, white);
  }

  .support-link {
    color: var(--accent) !important;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .support-link::before {
    content: "✦ ";
    opacity: 0.85;
  }

  .support-link:hover {
    color: color-mix(in oklab, var(--accent) 82%, white) !important;
  }

  @media (max-width: 600px) {
    .footer {
      padding: 0.75rem 0.75rem calc(0.75rem + env(safe-area-inset-bottom));
      font-size: 0.85rem;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }

    .footer-nav {
      margin-top: 0.5rem;
      padding-top: 0.5rem;
    }

    .link-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem 0.75rem;
      font-size: 0.85rem;
    }

    .link-grid a {
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer {
      transition: none;
    }
  }
</style>

<footer class="footer" role="contentinfo">
  <div class="footer-content">
    <p class="build-note">A Mind Arc Games Production</p>

    <nav class="footer-nav" aria-label="Footer links">
      <ul class="link-grid">
        <li>
          <a class="support-link" href="/support">Support Development</a>
        </li>

        <li><a href="/terms">Terms of Use</a></li>
        <li><a href="/privacy">Privacy</a></li>
      </ul>
    </nav>

    <p class="footer-contact">
      Get in touch:
      <a href="mailto:contact@mindarcgames.com">contact@mindarcgames.com</a>
    </p>

    <div class="social-links" aria-label="Social media links">
      <a
        href="https://youtube.com/@mindarcgames"
        target="_blank"
        rel="noopener"
      >
        <img src="/icons/youtube.svg" alt="YouTube" />
      </a>

      <a href="https://tiktok.com/@mindarcgames" target="_blank" rel="noopener">
        <img src="/icons/tiktok.svg" alt="TikTok" />
      </a>

      <a href="https://twitter.com/mindarcgames" target="_blank" rel="noopener">
        <img src="/icons/x.svg" alt="X / Twitter" />
      </a>
    </div>

    <p class="footer-subtext">
      © {year} Mind Arc Digital Entertainment LLC. All rights reserved.
    </p>
  </div>
</footer>
