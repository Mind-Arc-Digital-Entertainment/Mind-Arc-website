---
import CodexLayout from "../../../layouts/CodexLayout.astro";
import CodexEntry from "../../../components/codex/CodexEntry.astro";
import codexEntries from "../../../data/codex.json";

const currentPath = "/phoenixvector/codex/";

const currentEntry = codexEntries.find(
  (entry) => entry.href === currentPath
);

const meta = [
  { label: "Classification", value: "Public Archive" },
  { label: "Region", value: "Aurelia System" },
  { label: "Signal", value: "Stable" },
  { label: "Status", value: "Expanding" },
];
---

<CodexLayout
  pageTitle="Phoenix Vector Codex"
  currentPath={currentPath}
>
  {currentEntry && (
    <CodexEntry
      entry={currentEntry}
      meta={meta}
      featuredLabel="Featured Record"
      featuredTitle="The Aurelia System"
      featuredText="A binary star theater anchored by Neo Terra, Selara, and the strategic zones that define the Phoenix Vector conflict."
      exitHref="/phoenixvector/"
      exitLabel="Exit"
    />
  )}
</CodexLayout>