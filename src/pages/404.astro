---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="404 | Signal Lost">
  <main class="not-found-page">
    <div class="not-found-shell">
      <section class="not-found-panel">
        <p class="eyebrow">Mind Arc Games // Navigation Error</p>

        <p class="status-code">404</p>

        <h1>Access Denied</h1>

        <p class="lead">
          The page you’re attempting to access is unavailable.
        </p>

        <p class="subcopy">
          Clearance level inadequate. Access to this sector is restricted.
        </p>

        <div class="actions">
          <a href="/" class="btn btn-primary">Return Home</a>
          <a href="/phoenixvector/" class="btn btn-secondary">Enter Phoenix Vector</a>
          <a href="/phoenixvector/codex/" class="btn btn-secondary">Open Codex</a>
        </div>

        <div class="status-strip" aria-hidden="true">
          <span>LINK FAILURE</span>
          <span>ARCHIVE UNAVAILABLE</span>
          <span>SECTOR UNKNOWN</span>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  :root {
    --bg: #040814;
    --bg-soft: rgba(10, 18, 36, 0.82);
    --panel-border: rgba(103, 232, 249, 0.18);
    --text: #dbe7f5;
    --text-soft: #9fb2c9;
    --heading: #f8fbff;
    --cyan: #67e8f9;
    --gold: #ffc857;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
  }

  .not-found-page {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem 1.25rem;
    overflow: hidden;
    background:
      radial-gradient(circle at top center, rgba(34, 211, 238, 0.12), transparent 28%),
      radial-gradient(circle at 20% 20%, rgba(255, 200, 87, 0.08), transparent 18%),
      linear-gradient(180deg, #081120 0%, #040814 55%, #02050d 100%);
  }

  .not-found-page::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.08));
    pointer-events: none;
  }

  .not-found-shell {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 920px;
  }

  .not-found-panel {
    position: relative;
    padding: 2.5rem 2rem;
    text-align: center;
    border: 1px solid var(--panel-border);
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(103, 232, 249, 0.08), transparent 32%),
      linear-gradient(180deg, rgba(14, 25, 47, 0.9), rgba(7, 13, 26, 0.96));
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    overflow: hidden;
  }

.not-found-panel::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 24px;
  padding: 2px; /* thickness of the tape */

  background: repeating-linear-gradient(
    45deg,
    #000 0px,
    #000 10px,
    #ffc857 10px,
    #ffc857 20px
  );

  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;

  pointer-events: none;
}

  .eyebrow {
    margin: 0 0 0.9rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--cyan);
  }

  .status-code {
    margin: 0;
    font-size: clamp(4.5rem, 14vw, 8rem);
    line-height: 0.95;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--heading);
    text-shadow:
      0 0 18px rgba(103, 232, 249, 0.16),
      0 0 48px rgba(103, 232, 249, 0.08);
  }

  .not-found-panel h1 {
    margin: 0.75rem 0 0;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--heading);
  }

  .lead {
    max-width: 620px;
    margin: 1rem auto 0;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--gold);
    letter-spacing: 0.03em;
  }

  .subcopy {
    max-width: 680px;
    margin: 1rem auto 0;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.85;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 170px;
    padding: 0.95rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    color: #031018;
    background: linear-gradient(135deg, var(--cyan), #a5f3fc);
    box-shadow: 0 10px 30px rgba(103, 232, 249, 0.22);
  }

  .btn-primary:hover {
    box-shadow: 0 16px 34px rgba(103, 232, 249, 0.3);
  }

  .btn-secondary {
    color: var(--heading);
    border: 1px solid rgba(103, 232, 249, 0.22);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    border-color: rgba(103, 232, 249, 0.42);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.24);
  }

  .status-strip {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(103, 232, 249, 0.12);
  }

  .status-strip span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-soft);
    border: 1px solid rgba(103, 232, 249, 0.12);
    background: rgba(255, 255, 255, 0.025);
  }

  @media (max-width: 768px) {
    .not-found-page {
      padding: 1.5rem 1rem;
    }

    .not-found-panel {
      padding: 2rem 1.25rem;
      border-radius: 20px;
    }

    .not-found-panel::before {
      border-radius: 20px;
    }

    .actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      min-width: 0;
    }

    .lead {
      font-size: 0.98rem;
    }

    .subcopy {
      font-size: 0.96rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn {
      transition: none;
    }
  }
</style>