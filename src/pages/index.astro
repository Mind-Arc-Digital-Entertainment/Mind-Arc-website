---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="Mind Arc Games | Home">
  <main class="home-page">
    <div class="home-shell">
      <section class="hero">
        <h1>Worlds Beyond the Stars</h1>
        <div class="hero-actions"></div>
      </section>

      <section class="panel intro-panel">
        <div class="panel-header">
          <h2>Welcome to Mind Arc Games</h2>
        </div>

        <p>
          We're an independent creative studio focused on building a cinematic
          sci-fi experience with a strong visual identity and a nostalgic and
          memorable atmosphere.
        </p>

        <p>
          At the center of that mission is <strong>Phoenix Vector</strong>.
          Inspired by shooters of the late 80's and early 90s, its a
          high-intensity side-scrolling space combat experience set within a
          larger universe of conflict, mystery, and stellar ambition.
        </p>
      </section>

      <section class="panel feature-panel">
        <div class="feature-grid">
          <div class="feature-copy">
            <h2>Phoenix Vector</h2>
            <p>
              Enter the Aurelia System and engage in fast, precise combat across
              a war-torn frontier of drifting stations, hostile fleets, and
              glowing celestial horizons.
            </p>
            <p>
              Phoenix Vector combines arcade-inspired action with a bold sci-fi
              aesthetic, layered atmosphere, and a universe designed to expand.
            </p>

            <div class="feature-actions">
              <a href="/phoenixvector" class="btn btn-primary"
                >Explore Phoenix Vector</a
              >
            </div>
          </div>

          <div class="feature-card feature-card-image">
            <img src="../images/BrandCoreTitlePage.png" alt="Phoenix Vector" />
          </div>
        </div>
      </section>

      <section class="quick-links">


      </section>
    </div>
  </main>
</Layout>

<style>
  :root {
    --bg: #040814;
    --bg-soft: rgba(10, 18, 36, 0.82);
    --panel-border: rgba(103, 232, 249, 0.18);
    --text: #dbe7f5;
    --text-soft: #9fb2c9;
    --heading: #f8fbff;
    --cyan: #67e8f9;
    --cyan-strong: #22d3ee;
    --gold: #ffc857;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
  }



  .home-shell {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
  }

  .hero {
    text-align: center;
    padding: 1rem 1rem 3rem;
    margin-bottom: 2rem;
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(3rem, 7vw, 5.75rem);
    line-height: 0.95;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--heading);
    text-shadow:
      0 0 18px rgba(103, 232, 249, 0.14),
      0 0 42px rgba(103, 232, 249, 0.08);
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 190px;
    padding: 0.95rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    color: #031018;
    background: linear-gradient(135deg, var(--cyan), #a5f3fc);
    box-shadow: 0 10px 30px rgba(103, 232, 249, 0.22);
  }

  .btn-primary:hover {
    box-shadow: 0 16px 34px rgba(103, 232, 249, 0.3);
  }


  .panel {
    position: relative;
    margin-bottom: 1.5rem;
    padding: 2rem;
    border: 1px solid var(--panel-border);
    border-radius: 22px;
    background: linear-gradient(
      180deg,
      rgba(14, 25, 47, 0.88),
      rgba(7, 13, 26, 0.94)
    );
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
  }

  .panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 22px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(103, 232, 249, 0.35),
      rgba(255, 200, 87, 0.18),
      rgba(103, 232, 249, 0.1)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .panel-header {
    margin-bottom: 1rem;
  }

  .section-kicker {
    margin: 0 0 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .panel h2,
  .nav-card h3,
  .feature-card h3 {
    margin: 0;
    color: var(--heading);
    line-height: 1.1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .panel h2 {
    font-size: clamp(1.6rem, 3vw, 2.3rem);
  }

  .panel p,
  .nav-card p,
  .feature-card p {
    color: var(--text);
    line-height: 1.85;
    font-size: 1rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1.35fr 0.85fr;
    gap: 1rem;
    align-items: stretch;
  }

  .feature-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .feature-copy h2 {
    margin-bottom: 1rem;
  }

  .feature-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .feature-card-image {
    padding: 0;
    aspect-ratio: 16 / 9;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(103, 232, 249, 0.18);
    background: #000;
  }

  .feature-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }



  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .quick-links {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .home-page {
      padding: 3rem 1rem;
    }

    .hero {
      padding: 2.5rem 0.25rem 2rem;
    }

    .hero h1 {
      line-height: 1.02;
    }

    .panel {
      padding: 1.4rem;
      border-radius: 18px;
    }

    .panel::before {
      border-radius: 18px;
    }

    .btn {
      width: 100%;
      min-width: 0;
    }

    .hero-actions,
    .feature-actions {
      flex-direction: column;
    }

    .nav-card {
      padding: 1.25rem;
      border-radius: 18px;
    }
  }
</style>
